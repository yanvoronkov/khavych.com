generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Пользователи системы (ученики и администраторы)
model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  name           String
  phone          String
  role           Role         @default(USER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  additionalInfo String?
  orders         Order[]
  accesses       UserAccess[]
  certificates   Certificate[]

  @@index([email])
}

/// Обучающие курсы
model Course {
  id          String       @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  lessons     Lesson[]
  products    Product[]
  accesses    UserAccess[]
  certificates Certificate[]
}

/// Уроки внутри курсов
model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String
  videoUrl    String?
  videoCoverUrl String?
  fileUrls    String[]
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

/// Таблица связей для ручной выдачи доступа к курсам
model UserAccess {
  id        String    @id @default(uuid())
  userId    String
  courseId  String
  grantedAt DateTime  @default(now())
  expiresAt DateTime?
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

/// Каталог товаров, услуг и курсов в магазине
model Product {
  id          String   @id @default(uuid())
  name        Json
  description Json
  price       Float
  oldPrice    Float?
  imageUrl    String?
  category    Category
  subCategory String?
  features    Json?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  courseId    String?
  course      Course?  @relation(fields: [courseId], references: [id])

  @@index([courseId])
}

/// Заказы клиентов
model Order {
  id              String      @id @default(uuid())
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  customerAddress String?
  items           Json
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(10, 2)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([customerEmail])
}

/// Системные настройки (динамические конфигурации, например настройки бота Telegram)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Роли пользователей в системе
enum Role {
  USER
  ADMIN
}

/// Категории товаров в каталоге
enum Category {
  BRACELET
  COURSE
  CONSULTATION
}

/// Статусы заказов
enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

/// Выданные сертификаты пользователей
model Certificate {
  id            String   @id @default(uuid())
  userId        String
  courseId      String
  recipientName String   // Имя, которое вписал пользователь
  pdfUrl        String   // Ссылка на файл в Vercel Blob
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}
